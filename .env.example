# AI Image Generation Provider (options: 'stability-ai' or 'openai')
# Default: stability-ai (much cheaper - ~$0.004-0.02 per image vs $0.04-0.08)
AI_PROVIDER=stability-ai

# Stability AI API Key (RECOMMENDED - Much cheaper than OpenAI)
# Get your key from: https://platform.stability.ai/account/keys
# Cost: ~$0.004-0.02 per image (5-10x cheaper than DALL-E)
STABILITY_API_KEY=your_stability_api_key_here

# OpenAI API Key (Fallback option - more expensive)
# Get your key from: https://platform.openai.com/api-keys
# Cost: ~$0.04-0.08 per image
OPENAI_API_KEY=your_openai_api_key_here

# Printful — use the **wsbtees** store (Dashboard → Stores → wsbtees → API).
PRINTFUL_API_KEY=your_printful_api_key_here
# Simplest default: omit PRINTFUL_STORE_ID. At runtime we call GET /stores and pick wsbtees
# by name (PRINTFUL_STORE_NAME, default wsbtees) or the only store on the account.
# Override only if needed: numeric id (always works), or a name slug we resolve the same way.
# PRINTFUL_STORE_ID=
# PRINTFUL_STORE_NAME=wsbtees

# ImgBB API Key (Free - for hosting base64 images from Stability AI)
# Get your free key from: https://api.imgbb.com/
# This is needed when using Stability AI (which returns base64 images)
IMGBB_API_KEY=your_imgbb_api_key_here

# Stripe API Keys (for payment processing)
# Get your keys from: https://dashboard.stripe.com/apikeys
# Use test keys for development, live keys for production
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Next.js Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPPORT_EMAIL=support@yourdomain.com

# Stripe webhook secret (required for live webhook verification)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

